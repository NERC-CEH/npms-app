{
  "name": "npms-app",
  "id": "uk.ac.ceh.npms",
  "title": "NPMS App",
  "version": "2.0.0",
  "scripts": {
    "prepare": "husky",
    "start": "webpack serve --progress --port 8000",
    "build": "NODE_ENV=production webpack",
    "build:production": "npm run clean && npm run build && npx cap sync && npm run build:resources",
    "build:resources": "mkdir -p resources && cp -R other/designs/android resources && cp -R other/designs/*.png resources && npx cordova-res ios --skip-config --resources resources --copy && npx cordova-res android --skip-config --resources resources --copy",
    "deploy": "cp other/demo.html build/ && URL=$(vercel --prod -t $VERCEL_TOKEN --yes -A ./other/vercel.json ./build) && CLEAN_URL=$(echo $URL | sed -r \"s/https:\\/\\/(.*)$/\\1/g\") && DEMO_URL=$(echo $CLEAN_URL | sed -r \"s/(.*\\-)[a-z0-9]+\\-flumens(\\.vercel\\.app)$/\\1${BITRISE_BUILD_NUMBER}\\2/g\") && envman add --key DEMO_URL --value \"https://$DEMO_URL\"",
    "deploy:production": "bitrise run ci",
    "check": "npx tsc --noEmit --skipLibCheck && npm run test:eslint",
    "clean": "rm -rf build resources",
    "test": "jest --silent --passWithNoTests",
    "test:watch": "jest --watchAll",
    "test:eslint": "eslint src --quiet && echo '\\033[37;42;1m PASS \\033[00m'",
    "make:species": "cd src/common/data && tsx make.ts"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/camera": "8.2.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/device": "8.0.2",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/geolocation": "8.2.0",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.1",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/network": "8.0.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@flumens/bigu": "0.4.1",
    "@flumens/ionic": "2.0.0-alpha.102",
    "@flumens/models": "0.27.0",
    "@flumens/tailwind": "0.42.0",
    "@flumens/utils": "0.12.0",
    "@heroicons/react": "2.2.0",
    "@hookform/resolvers": "5.4.0",
    "@ionic-native/core": "5.36.0",
    "@ionic/core": "8.8.11",
    "@ionic/react": "8.8.11",
    "@ionic/react-router": "8.8.11",
    "@react-stately/form": "^3.3.1",
    "@sentry/browser": "10.59.0",
    "axios": "1.18.0",
    "capacitor-blob-writer": "^1.1.19",
    "clsx": "2.1.1",
    "deep-diff": "1.0.2",
    "drizzle-orm": "0.45.2",
    "i18next": "26.3.1",
    "ionicons": "8.0.13",
    "jeep-sqlite": "2.8.0",
    "jwt-decode": "4.0.0",
    "lodash": "4.18.1",
    "mobx": "6.16.1",
    "mobx-react": "9.2.2",
    "mobx-utils": "6.1.1",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-i18next": "17.0.8",
    "react-router": "5.3.4",
    "react-router-dom": "5.3.4",
    "sql.js": "1.12.0",
    "swiper": "12.2.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-private-property-in-object": "7.21.11",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-transform-exponentiation-operator": "7.28.6",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@capacitor/cli": "8.4.1",
    "@flumens/eslint-config": "3.0.2",
    "@flumens/prettier-config": "0.4.0",
    "@flumens/webpack-config": "6.0.5",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-router": "5.1.20",
    "@types/react-router-dom": "5.3.3",
    "babel-jest": "30.4.1",
    "babel-plugin-module-resolver": "5.0.3",
    "copy-webpack-plugin": "14.0.0",
    "cordova-res": "0.15.4",
    "dotenv": "17.4.2",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-transform-stub": "2.0.0",
    "mock-geolocation": "1.0.11",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.1",
    "tailwindcss-theme-swapper": "0.12.0",
    "tslib": "2.8.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vercel": "54.14.2",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.5"
  },
  "browserslist": [
    "ChromeAndroid >= 89",
    "iOS >= 15"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "author": {
    "name": "Flumens",
    "email": "enquiries@flumens.io",
    "url": "https://flumens.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FlumensIO/e-surveyor-app"
  },
  "bugs": {
    "url": "https://github.com/FlumensIO/e-surveyor-app/issues"
  },
  "licenses": [
    {
      "type": "GNU GPL v3",
      "url": "http://www.gnu.org/licenses/gpl.html"
    }
  ],
  "keywords": [
    "biological",
    "recording",
    "mobile",
    "app",
    "offline",
    "ceh"
  ],
  "babel": {
    "presets": [
      [
        "@babel/react",
        {
          "runtime": "automatic"
        }
      ],
      [
        "@babel/env",
        {
          "loose": true,
          "modules": "commonjs",
          "corejs": "3.22",
          "useBuiltIns": "usage"
        }
      ],
      [
        "@babel/typescript",
        {
          "allowDeclareFields": true
        }
      ]
    ],
    "plugins": [
      [
        "@babel/transform-runtime",
        {
          "regenerator": true
        }
      ],
      [
        "module-resolver",
        {
          "root": [
            "./src"
          ],
          "alias": {
            "@flumens$": "./src/common/flumens",
            "common": "./src/common",
            "helpers": "./src/common/helpers",
            "models": "./src/common/models",
            "Components": "./src/common/Components"
          }
        }
      ],
      [
        "@babel/proposal-private-property-in-object",
        {
          "loose": true
        }
      ],
      "@babel/transform-exponentiation-operator",
      "@babel/syntax-dynamic-import"
    ]
  },
  "prettier": "@flumens/prettier-config",
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "babel-jest",
        {
          "presets": [
            "@babel/env"
          ]
        }
      ]
    },
    "testRegex": "src.*((\\.|/*.)(spec))\\.(t|j)s?$",
    "moduleNameMapper": {
      "^.+.(css|style|less|sass|scss|svg|png|jpg|ttf|woff|woff2)$": "jest-transform-stub",
      "ionic-native": "jest-transform-stub",
      "swiper": "jest-transform-stub"
    },
    "moduleDirectories": [
      "node_modules",
      "components",
      "src"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setupTests.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!@ionic|@stencil|ionicons)"
    ]
  }
}
